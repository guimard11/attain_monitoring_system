	measure Total_loan = EXTERNALMEASURE("Total_loan", DOUBLE, "DirectQuery to AS - SM_success")
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 76efc021-58d8-484a-a49e-3edb8ed712ce
		sourceLineageTag: 970e6d3a-aa75-4199-8253-1df6907a8e28
