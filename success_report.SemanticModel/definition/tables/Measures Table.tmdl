	measure Total_sales = EXTERNALMEASURE("Total_sales", INTEGER, "DirectQuery to AS - SM_success")
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: ef6fb55e-b90a-4f3c-a1b9-1f04f4c9666e
		sourceLineageTag: 2cdaf3e5-d79f-4936-a917-3911ff68db54
