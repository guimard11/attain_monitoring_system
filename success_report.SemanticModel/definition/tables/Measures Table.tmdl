	measure MSME_target = 1.1*[Total_MSMEs]
		formatString: 0
		lineageTag: 7464a8f6-e6fe-4b31-b037-ea443392783b

	measure Total_attendance = SUM(activity_fact[attendance_number])
		formatString: 0
		lineageTag: 936f32af-02af-428b-b45a-def8b208b184

		changedProperty = Name

	measure Total_training_days = (SUM(activity_fact[activity_duration])/8)
		formatString: 0
		lineageTag: ec83cc41-50a9-4ca4-8438-a776456a6bc5

		changedProperty = Name

		changedProperty = FormatString

	measure Total_SME_loan_approved =
			
			CALCULATE(
			    COUNTROWS(success_profile),
			    success_profile[financial_institution] = "yes"
			)
		formatString: 0
		lineageTag: 7199fe82-efbe-4d9c-b2cf-e8fcd62ff8fd

		changedProperty = Name

	measure Current_month_sales = CALCULATE([Total_sales],DATESMTD(date_sales[date_sales_id]))
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: f18a580c-2985-4241-8ed6-d16ad8342409

		changedProperty = Name

		changedProperty = FormatString

	measure Last_month_sales = CALCULATE([Total_sales],DATEADD(date_sales[date_sales_id],-1,MONTH))
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 14e39a78-9ac8-4c76-9bbd-83875831c433

		changedProperty = Name

		changedProperty = FormatString

	measure Sales_target = ([Total_sales]*1.05)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: db9b8868-d369-4dfa-b2e1-5354780d2aec

		changedProperty = Name

		changedProperty = FormatString

	measure job_created_target = ([Total_jobs_created]*1.1)
		formatString: 0
		lineageTag: c9f4137b-644e-4da1-a9da-b0e9afbe52f3

		changedProperty = Name

		changedProperty = FormatString

	measure Current_month_job = CALCULATE([Total_jobs_created],DATESMTD(date_job[date_job_id]))
		formatString: 0
		lineageTag: db78f23d-a71a-4bda-b408-cd61fedfce60

